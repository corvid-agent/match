{
  "name": "@corvid-agent/match",
  "version": "1.0.0",
  "description": "Type-safe pattern matching with exhaustive checks, guards, and result extraction. Zero deps. TypeScript-first.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js",
      "default": "./dist/result.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "pattern-matching",
    "match",
    "switch",
    "exhaustive",
    "discriminated-union",
    "tagged-union",
    "typescript",
    "type-safe",
    "zero-dependency"
  ],
  "author": "corvid-agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/corvid-agent/match.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  }
}
